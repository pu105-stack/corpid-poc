# CorpID Sandbox credentials (from Developer Portal → Account → User Credentials)
CORPID_CLIENT_ID=your_corpid_client_id
CORPID_CLIENT_SECRET=your_corpid_client_secret

# iAM Smart ITE credentials (from iAM Smart ITE self-service portal)
IAMSMART_CLIENT_ID=your_iamsmart_client_id
IAMSMART_CLIENT_SECRET=your_iamsmart_client_secret

# KEK certificate (the Hongkong Post Trial Certificate provided in the sandbox)
KEK_P12_PATH=../account-centre-kek.p12
KEK_P12_PIN=8568185550716550

# Public HTTPS base URL for callbacks (use ngrok for form pre-filling)
# For auth-only (no form filling), localhost works fine:
#   CALLBACK_BASE_URL=http://localhost:3000
# For form pre-filling, you need a public HTTPS URL:
#   CALLBACK_BASE_URL=https://xxxx.ngrok-free.app
CALLBACK_BASE_URL=http://localhost:3000

PORT=3000
